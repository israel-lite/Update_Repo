{
  "version": 2,
  "builds": [
    {
      "src": "simple_ai_server.py",
      "use": "@vercel/python"
    },
    {
      "src": "chatgpt-style.html",
      "use": "@vercel/static"
    },
    {
      "src": "clone.html",
      "use": "@vercel/static"
    },
    {
      "src": "login.html",
      "use": "@vercel/static"
    },
    {
      "src": "eazee-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "js/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/simple_ai_server.py"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "functions": {
    "simple_ai_server.py": {
      "runtime": "python3.9"
    }
  }
}
